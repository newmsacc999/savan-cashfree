# ─────────────────────────────────────────────────────────────────────────────
# FRONTEND env (Vite) — used at BUILD time. On Vercel, set these in the
# Project → Settings → Environment Variables (do NOT commit real values).
# ─────────────────────────────────────────────────────────────────────────────

# The one switch: which gateway is active — razorpay | cashfree
VITE_PAYMENT_PROVIDER=cashfree

# Razorpay PUBLIC key id — safe in the frontend (used by the in-page popup).
# Use a TEST key while testing: rzp_test_...
VITE_RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx

# Absolute origin of the PHP payment backend on Hostinger (no trailing slash).
# Used by Cashfree only (redirect + order_status.php).
VITE_PHP_BASE_URL=https://your-site.hostingersite.com

# ─────────────────────────────────────────────────────────────────────────────
# BACKEND env — these are read by load_env.php on HOSTINGER (PHP) only.
# They are NOT used by Vite/Vercel. Put them in the .env you upload to Hostinger.
# ─────────────────────────────────────────────────────────────────────────────

# CASHFREE_APP_ID="your_app_id"
# CASHFREE_SECRET_KEY="cfsk_ma_prod_xxx"   # cfsk_ma_test_... for sandbox
# CASHFREE_ENVIRONMENT="PRODUCTION"        # or "SANDBOX" while testing
# APP_BASE_URL="https://your-frontend.vercel.app/thank-you"  # both gateways return here

# RAZORPAY_KEY_ID="rzp_live_xxx"           # rzp_test_... while testing
# RAZORPAY_KEY_SECRET="your_razorpay_secret"
